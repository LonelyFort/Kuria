        "## Test pre-trained model performance with test-image\n",
        "import numpy as np\n",
        "from timeit import default_timer as timer\n",
        "from PIL import Image\n",
        "import cv2\n",
        "from ppocr. postprocess import build_post_process\n",
        "from torchvision import transforms\n",
        "\n",
        "def predict_image(\n",
        "    model: paddle.nn.Layer,\n",
        "    image_path: str,\n",
        "    transform=None,\n",
        "    device=\"cpu\"\n",
        "):\n",
        "\n",
        "    # Load image\n",
        "    image = Image.open(image_path).convert('RGB')\n",
        "    src_w, src_h = image. size\n",
        "    paddle.set_device(device)\n",
        "\n",
        "    target_size = (224, 224)\n",
        "\n",
        "    if transform is not None:\n",
        "        image_transform = transform\n",
        "    else:\n",
        "        image_transform = transforms. Compose([\n",
        "            transforms.Resize(target_size),\n",
        "            transforms.ToTensor(),\n",
        "            transforms.Normalize(mean=[0.485, 0.456, 0.406],\n",
        "                                std=[0.229, 0.224, 0.225])\n",
        "        ])\n",
        "\n",
        "    # Transform image\n",
        "    transformed_image = paddle.to_tensor(image_transform(image).numpy())\n",
        "    transformed_image = paddle.unsqueeze(transformed_image, axis=0)\n",
        "    transformed_image = paddle.to_tensor(transformed_image, dtype='float32')\n",
        "\n",
        "    # Prep model\n",
        "    model.eval()\n",
        "    start_time = timer()\n",
        "\n",
        "    # Make predictions\n",
        "    with paddle.no_grad():\n",
        "        preds = model(transformed_image)\n",
        "\n",
        "    end_time = timer()\n",
        "    prediction_time = end_time - start_time\n",
        "    print(f\"Prediction time: {prediction_time:.4f}s\")\n",
        "\n",
        "    # Post process to get bounding boxes\n",
        "    scale_h = target_size[0] / src_h\n",
        "    scale_w = target_size[1] / src_w\n",
        "    shape_list = np. array([[src_h, src_w, scale_h, scale_w]])\n",
        "\n",
        "    post_process = build_post_process(config[\"PostProcess\"])\n",
        "    post_result = post_process(preds, shape_list)\n",
        "\n",
        "    # Extract boxes\n",
        "    boxes = []\n",
        "    if post_result and len(post_result) > 0:\n",
        "        if 'points' in post_result[0]:\n",
        "            boxes = post_result[0]['points']\n",
        "\n",
        "    # Get probability map\n",
        "    if isinstance(preds, dict):\n",
        "        prob_map = preds. get('maps', preds.get('binary', None))\n",
        "        if prob_map is not None:\n",
        "            prob_map = prob_map.numpy()[0, 0]\n",
        "        else:\n",
        "            prob_map = list(preds. values())[0].numpy()[0, 0]\n",
        "    else:\n",
        "        prob_map = preds.numpy()[0, 0]\n",
        "\n",
        "    prob_h, prob_w = prob_map.shape\n",
        "    print(f\"Probability map shape: {prob_map.shape}\")\n",
        "    print(f\"Original image size: {src_w}x{src_h}\")\n",
        "\n",
        "    # Calculate scores from probability map\n",
        "    scores = []\n",
        "    for box in boxes:\n",
        "        box = np.array(box)\n",
        "\n",
        "        # Scale box from original image coordinates to prob_map coordinates\n",
        "        scaled_box = box. copy()\n",
        "        scaled_box[: , 0] = box[:, 0] * (prob_w / src_w)  # x coordinates\n",
        "        scaled_box[:, 1] = box[:, 1] * (prob_h / src_h)  # y coordinates\n",
        "        scaled_box = scaled_box.astype(np.int32)\n",
        "\n",
        "        # Clip coordinates to valid range\n",
        "        scaled_box[: , 0] = np.clip(scaled_box[:, 0], 0, prob_w - 1)\n",
        "        scaled_box[:, 1] = np. clip(scaled_box[:, 1], 0, prob_h - 1)\n",
        "\n",
        "        # Create a mask for the box region\n",
        "        mask = np.zeros((prob_h, prob_w), dtype=np.uint8)\n",
        "        cv2.fillPoly(mask, [scaled_box], 1)\n",
        "\n",
        "        # Calculate mean probability within the box\n",
        "        box_probs = prob_map[mask == 1]\n",
        "        if len(box_probs) > 0:\n",
        "            score = float(np.mean(box_probs))\n",
        "        else:\n",
        "            score = 0.0\n",
        "\n",
        "        scores. append(score)\n",
        "\n",
        "    img = cv2.imread(image_path)\n",
        "    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
        "\n",
        "    # Draw bounding boxes\n",
        "    for i, box in enumerate(boxes):\n",
        "        box = np.array(box).astype(np.int32)\n",
