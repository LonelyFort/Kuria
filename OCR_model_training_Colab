        "\n",
        "        # Draw score\n",
        "        if i < len(scores):\n",
        "            score = scores[i]\n",
        "            cv2.putText(img, f\"{score:.2f}\", tuple(box[0]),\n",
        "                        cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 0, 0), 2)\n",
        "\n",
        "    # Plot\n",
